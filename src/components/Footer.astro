---
import { getLang, localizePath } from '../i18n/utils';
import { useUI, ROUTES, SERVICE_NAV } from '../i18n/ui';
import { company } from '../i18n/company';

const lang = getLang(Astro.currentLocale);
const t = useUI(lang);
const lp = (p: string) => localizePath(p, lang);
const year = 2026; // 建置年份；可改為動態
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/brand/twouring-logo-white.svg" alt={company.brand} width="160" height="44" />
      <p class="footer-tagline">{t.footer.tagline}</p>
      <a class="footer-linkedin" href={company.linkedin} target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.94 5a2 2 0 11-4 0 2 2 0 014 0zM3.3 8.5h3.3V21H3.3V8.5zM9.3 8.5h3.16v1.7h.05c.44-.83 1.5-1.7 3.1-1.7 3.32 0 3.93 2.18 3.93 5.02V21h-3.3v-5.55c0-1.32-.02-3.02-1.84-3.02-1.84 0-2.12 1.44-2.12 2.92V21H9.3V8.5z"/></svg>
        <span>{t.footer.followLinkedin}</span>
      </a>
    </div>

    <nav class="footer-col" aria-label={t.footer.servicesTitle}>
      <h2>{t.footer.servicesTitle}</h2>
      <ul>
        {SERVICE_NAV.map((s) => (<li><a href={lp(s.path)}>{t.serviceNav[s.key]}</a></li>))}
        <li><a href={lp(ROUTES.services)}>{t.nav.servicesOverview}</a></li>
      </ul>
    </nav>

    <nav class="footer-col" aria-label={t.footer.companyTitle}>
      <h2>{t.footer.companyTitle}</h2>
      <ul>
        <li><a href={lp(ROUTES.about)}>{t.nav.about}</a></li>
        <li><a href={lp(ROUTES.cases)}>{t.nav.cases}</a></li>
        <li><a href={lp(ROUTES.contact)}>{t.nav.contact}</a></li>
      </ul>
    </nav>

    <div class="footer-col footer-contact">
      <h2>{t.footer.contactTitle}</h2>
      <ul>
        <li><a href={`mailto:${company.email}`}>{company.email}</a></li>
        <li>{company.address[lang]}</li>
      </ul>
    </div>
  </div>

  <div class="container footer-legal-row">
    <div class="footer-legal">
      <p class="legal-name">{company.legalName[lang]}{lang === 'zh' ? '' : ''} · {company.legalName[lang === 'zh' ? 'en' : 'zh']}</p>
      <p class="legal-meta">
        <span>{t.footer.taxIdLabel}：{company.taxId}</span>
        <span>{lang === 'zh' ? '代表人' : 'Representative'}：{company.representative[lang]}</span>
      </p>
      <p class="legal-note">{t.footer.legalNote}</p>
    </div>
    <div class="footer-bottom">
      <ul class="footer-policies">
        <li><a href={lp(ROUTES.privacy)}>{t.footer.privacy}</a></li>
        <li><a href={lp(ROUTES.terms)}>{t.footer.terms}</a></li>
        <li><a href={lp(ROUTES.cookies)}>{t.footer.cookies}</a></li>
      </ul>
      <p class="copyright">© {year} {company.legalName[lang]}. {t.footer.rights}.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--c-surface-ink); color: #aeb3ba; padding-block: clamp(3rem, 6vw, 4.5rem) 2rem; margin-top: auto; }
  .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.4fr; gap: 2.5rem 1.5rem; }
  .footer-brand img { height: 40px; width: auto; margin-bottom: 1rem; }
  .footer-tagline { max-width: 34ch; color: #c4c9cf; }
  .footer-linkedin { display: inline-flex; align-items: center; gap: 0.5em; margin-top: 1.2rem; color: #e4e7ea; font-weight: 600; }
  .footer-linkedin:hover { color: var(--c-accent-2); }

  .footer-col h2 { font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; margin-bottom: 1rem; font-family: var(--font-head); }
  .footer-col ul { display: grid; gap: 0.6rem; }
  .footer-col a { color: #aeb3ba; }
  .footer-col a:hover { color: #fff; }
  .footer-contact li { color: #aeb3ba; }

  .footer-legal-row { margin-top: 3rem; padding-top: 1.8rem; border-top: 1px solid rgba(255,255,255,0.1); display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: end; }
  .legal-name { color: #e4e7ea; font-weight: 600; font-family: var(--font-head); }
  .legal-meta { display: flex; flex-wrap: wrap; gap: 0.4rem 1.4rem; font-size: 0.88rem; margin-top: 0.4rem; }
  .legal-note { font-size: 0.82rem; color: #868c94; margin-top: 0.8rem; max-width: 70ch; }
  .footer-bottom { text-align: right; }
  .footer-policies { display: flex; gap: 1.2rem; justify-content: flex-end; margin-bottom: 0.6rem; }
  .footer-policies a { color: #aeb3ba; font-size: 0.88rem; }
  .footer-policies a:hover { color: #fff; }
  .copyright { font-size: 0.82rem; color: #868c94; }

  @media (max-width: 880px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
    .footer-legal-row { grid-template-columns: 1fr; }
    .footer-bottom { text-align: left; }
    .footer-policies { justify-content: flex-start; }
  }
  @media (max-width: 520px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
