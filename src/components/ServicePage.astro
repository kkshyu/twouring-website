---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from './PageHero.astro';
import CTABand from './CTABand.astro';
import Icon from './Icon.astro';
import { getLang, localizePath } from '../i18n/utils';
import { useUI, ROUTES } from '../i18n/ui';
import { company } from '../i18n/company';
import { services, type ServiceSlug } from '../data/services';

interface Props { slug: ServiceSlug; }
const { slug } = Astro.props;
const lang = getLang(Astro.currentLocale);
const t = useUI(lang);
const lp = (p: string) => localizePath(p, lang);
const d = services[slug][lang];
const path = services[slug].path;

const proc = {
  zh: [
    { t: '資格判斷會議', d: '30 分鐘判斷問題是否清楚、是否有預算與決策者。' },
    { t: '付費診斷', d: '盤點現況、利害關係人與資源，產出最高優先機會與 90 天路線圖。' },
    { t: '顧問 / PMO', d: '把診斷轉成執行：例會、策略文件、導入追蹤與 KPI。' },
    { t: '導入與年度合作', d: '專案導入、培訓、年度顧問，並把成果轉成可公開案例。' },
  ],
  en: [
    { t: 'Qualification call', d: '30 minutes to confirm the problem, budget and decision-maker.' },
    { t: 'Paid diagnostic', d: 'Map the status quo, stakeholders and resources into priorities and a 90-day roadmap.' },
    { t: 'Advisory / PMO', d: 'Turn the diagnostic into delivery: cadence, strategy docs, adoption tracking and KPIs.' },
    { t: 'Rollout & annual', d: 'Project rollout, training, annual advisory — and turning results into public cases.' },
  ],
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.title,
  serviceType: d.eyebrow,
  description: d.lead,
  provider: { '@id': company.siteUrl + '/#organization' },
  areaServed: ['TW', 'Asia'],
  url: company.siteUrl + lp(path),
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: lang === 'zh' ? '首頁' : 'Home', item: company.siteUrl + lp(ROUTES.home) },
    { '@type': 'ListItem', position: 2, name: t.nav.services, item: company.siteUrl + lp(ROUTES.services) },
    { '@type': 'ListItem', position: 3, name: d.title, item: company.siteUrl + lp(path) },
  ],
};
---
<BaseLayout title={d.title} description={d.metaDescription} path={path} jsonLd={[serviceLd, breadcrumbLd]}>
  <PageHero
    eyebrow={d.eyebrow}
    title={d.title}
    lead={d.lead}
    crumbs={[{ label: t.nav.services, path: ROUTES.services }, { label: d.navLabel }]}
  >
    <div class="hero-pills">
      {d.highlights.map((h) => (<span class="hero-pill"><Icon name="check" size={16} />{h}</span>))}
    </div>
    <div class="cluster hero-cta">
      <a class="btn btn--primary btn--lg" href={lp(ROUTES.contact)}>{t.cta.primary}</a>
      <a class="btn btn--ghost btn--lg" href={lp(ROUTES.cases)}>{t.cta.viewCases}</a>
    </div>
  </PageHero>

  <!-- 痛點 -->
  <section class="section section--surface">
    <div class="container">
      <div class="section-head"><p class="eyebrow">{t.common.painPoints}</p><h2>{d.painTitle}</h2></div>
      <ul class="grid grid--2 pain-grid">
        {d.painPoints.map((p) => (
          <li class="pain-card"><span class="pain-mark" aria-hidden="true"><Icon name="x" size={18} /></span><p>{p}</p></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 解法 -->
  <section class="section">
    <div class="container solution-wrap">
      <div class="solution-copy">
        <p class="eyebrow">{t.common.ourSolution}</p>
        <h2>{d.solutionTitle}</h2>
        <p class="lead">{d.solutionLead}</p>
        <ul class="solution-list">
          {d.solutionPoints.map((s) => (<li><Icon name="check" size={20} class="sl-icon" /><span>{s}</span></li>))}
        </ul>
      </div>
      <aside class="pitch-card">
        <Icon name="spark" size={26} class="pitch-icon" />
        <p class="pitch-quote">{d.pitch}</p>
      </aside>
    </div>
  </section>

  <!-- 服務包與價格 -->
  <section class="section section--warm">
    <div class="container">
      <div class="section-head"><p class="eyebrow">{t.common.packages}</p><h2>{d.packagesTitle}</h2><p class="lead">{d.packagesNote}</p></div>
      <div class="grid grid--3 pkg-grid">
        {d.packages.map((p) => (
          <article class="card pkg-card">
            <h3 class="pkg-name">{p.name}</h3>
            <p class="pkg-price">{p.price}</p>
            <p class="pkg-desc">{p.desc}</p>
          </article>
        ))}
      </div>
      <p class="price-note">{d.priceFootnote}</p>
    </div>
  </section>

  <!-- 適合 / 不適合 -->
  <section class="section">
    <div class="container fit-grid">
      <div class="fit-col fit-good">
        <h3><Icon name="check" size={22} /> {t.common.goodFit}</h3>
        <ul>{d.goodFit.map((g) => (<li>{g}</li>))}</ul>
      </div>
      <div class="fit-col fit-bad">
        <h3><Icon name="x" size={22} /> {t.common.notFit}</h3>
        <ul>{d.notFit.map((g) => (<li>{g}</li>))}</ul>
      </div>
    </div>
  </section>

  <!-- 合作流程 -->
  <section class="section section--surface">
    <div class="container">
      <div class="section-head center"><p class="eyebrow">{t.common.process}</p><h2>{lang === 'zh' ? '從一場會議到可持續的成果' : 'From one call to lasting results'}</h2></div>
      <ol class="steps">
        {proc[lang].map((s, i) => (
          <li class="step"><span class="step-num">{i + 1}</span><div><h4>{s.t}</h4><p>{s.d}</p></div></li>
        ))}
      </ol>
    </div>
  </section>

  {d.deliverables && (
    <section class="section">
      <div class="container">
        <div class="section-head"><p class="eyebrow">{t.common.deliverables}</p><h2>{lang === 'zh' ? '你會拿到什麼' : 'What you receive'}</h2></div>
        <ul class="grid grid--2 deliver-grid">
          {d.deliverables.map((x) => (<li class="deliver-item"><Icon name="doc" size={20} class="di-icon" /><span>{x}</span></li>))}
        </ul>
      </div>
    </section>
  )}

  <CTABand />
</BaseLayout>

<style>
  .hero-pills { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.4rem; }
  .hero-pill { display: inline-flex; align-items: center; gap: 0.4em; background: #fff; border: 1px solid var(--c-line); border-radius: var(--radius-pill); padding: 0.45em 0.9em; font-size: 0.9rem; font-weight: 600; box-shadow: var(--shadow-sm); }
  .hero-pill :global(svg) { color: var(--c-accent-strong); }
  .hero-cta { margin-top: 1.8rem; }

  .pain-grid { gap: 1rem; }
  .pain-card { display: flex; gap: 0.9rem; align-items: flex-start; background: #fff; border: 1px solid var(--c-line); border-radius: var(--radius); padding: 1.1rem 1.2rem; }
  .pain-mark { flex-shrink: 0; display: grid; place-items: center; width: 34px; height: 34px; border-radius: 50%; background: var(--c-accent-soft); color: var(--c-accent-strong); }
  .pain-card p { color: var(--c-ink); }

  .solution-wrap { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.5rem; align-items: start; }
  .solution-list { margin-top: 1.4rem; display: grid; gap: 0.8rem; }
  .solution-list li { display: flex; gap: 0.7rem; align-items: flex-start; }
  .sl-icon { color: var(--c-accent-strong); flex-shrink: 0; margin-top: 2px; }
  .pitch-card { background: var(--c-surface-ink); color: #fff; border-radius: var(--radius-lg); padding: 1.8rem; box-shadow: var(--shadow); position: sticky; top: 90px; }
  .pitch-icon { color: var(--c-accent-2); margin-bottom: 0.8rem; }
  .pitch-quote { font-family: var(--font-head); font-weight: 700; font-size: var(--fs-500); line-height: 1.45; color: #fff; }

  .pkg-grid { gap: 1.2rem; }
  .pkg-card { display: flex; flex-direction: column; }
  .pkg-name { font-size: var(--fs-500); }
  .pkg-price { font-family: var(--font-head); font-weight: 800; color: var(--c-accent-strong); margin: 0.5rem 0 0.8rem; font-size: 1.05rem; }
  .pkg-desc { color: var(--c-muted); font-size: 0.96rem; }
  .price-note { margin-top: 1.4rem; font-size: 0.88rem; color: var(--c-faint); max-width: 70ch; }

  .fit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .fit-col { border-radius: var(--radius-lg); padding: 1.6rem 1.8rem; border: 1px solid var(--c-line); }
  .fit-col h3 { display: flex; align-items: center; gap: 0.5em; margin-bottom: 1rem; font-size: var(--fs-500); }
  .fit-col ul { display: grid; gap: 0.6rem; }
  .fit-col li { padding-left: 1.1em; position: relative; color: var(--c-ink); }
  .fit-col li::before { content: ""; position: absolute; left: 0; top: 0.6em; width: 6px; height: 6px; border-radius: 50%; }
  .fit-good { background: #f3faf5; border-color: #d7eede; }
  .fit-good h3 :global(svg) { color: #1a8a4f; }
  .fit-good li::before { background: #1a8a4f; }
  .fit-bad { background: var(--c-surface); }
  .fit-bad h3 :global(svg) { color: var(--c-faint); }
  .fit-bad li::before { background: var(--c-faint); }

  .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; counter-reset: step; }
  .step { display: grid; gap: 0.6rem; }
  .step-num { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 50%; background: var(--grad-brand); color: #fff; font-family: var(--font-head); font-weight: 800; }
  .step h4 { font-size: var(--fs-400); }
  .step p { font-size: 0.92rem; color: var(--c-muted); }

  .deliver-grid { gap: 0.8rem; }
  .deliver-item { display: flex; gap: 0.7rem; align-items: flex-start; background: var(--c-surface); border-radius: var(--radius); padding: 0.9rem 1.1rem; }
  .di-icon { color: var(--c-accent-strong); flex-shrink: 0; margin-top: 2px; }

  @media (max-width: 860px) {
    .solution-wrap { grid-template-columns: 1fr; }
    .pitch-card { position: static; }
    .steps { grid-template-columns: 1fr 1fr; }
    .fit-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) { .steps { grid-template-columns: 1fr; } }
</style>
